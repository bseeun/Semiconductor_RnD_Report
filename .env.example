OPENAI_API_KEY=
# 웹 검색 (Tavily API — https://tavily.com)
TAVILY_API_KEY=
# 선택: general | news | finance — news 는 결과에 published_date 가 붙는 경우가 많음
# TAVILY_TOPIC=news
# (고급) 컨텍스트/문서 수 튜닝 (기본값은 agents.py 참고)
# WEB_MAX_RESULTS=8
# RAG_N_RESULTS=8
# BALANCED_K=50
# ANALYST_DOCS_MAX=35
# EXTRACTIONS_MAX=60
# Hugging Face (임베딩 모델 다운로드 가속·rate limit)
# HF_TOKEN=

# 선택: Chroma / 균형 단계
# CHROMA_PERSIST_DIR=./chroma_db
# EMBEDDING_MODEL=BAAI/bge-m3
# MIN_CREDIBILITY_FOR_BALANCE=0.38
# MMR_LAMBDA=0.65
# MMR_POOL_SIZE=60

# LangSmith (https://smith.langchain.com → API Keys)
# 아래 키가 있으면 LANGCHAIN_TRACING_V2 를 비워도 자동으로 true (끄려면 LANGSMITH_TRACING=false)
# LANGCHAIN_API_KEY=
# 또는 동일: LANGSMITH_API_KEY=
# LANGCHAIN_PROJECT=semiconductor-rnd
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_TRACING=false
